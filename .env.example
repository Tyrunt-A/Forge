# Copy this file to .env and fill in your keys

# Riot Games API key — get one at https://developer.riotgames.com
RIOT_API_KEY=your_riot_api_key_here

# Anthropic API key — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Riot platform region (euw1, na1, la1, la2, br1, kr, etc.)
RIOT_REGION=euw1

# Claude model to use (optional — defaults to Sonnet)
# Use claude-haiku-4-5-20251001 for lower cost
FORGE_MODEL=claude-sonnet-4-6
